    <sys:String x:Key="AutoTranslateDisabled">Otomatik Çeviriyi Devre Dışı Bırak</sys:String>
    <sys:String x:Key="General_AutoStartup">Otomatik Başlat</sys:String>
    <sys:String x:Key="General_AutoStartupDescription">Bilgisayar açıldığında yazılımı otomatik olarak başlatır.</sys:String>
    <sys:String x:Key="General_StartMode">Başlangıç Modu</sys:String>
    <sys:String x:Key="General_StartModeDescription">"SkipUACAdmin", UAC açılır penceresini atlamak için zamanlanmış bir görev oluşturur.</sys:String>
    <sys:String x:Key="General_HideOnStartup">Sistem Başlangıcında Pencereyi Gizle</sys:String>
    <sys:String x:Key="General_HideOnStartupDescription">STranslate başladığında arama penceresi sistem tepsisine gizlenir.</sys:String>
    <sys:String x:Key="General_HideWhenDeactivated">Odak Kaybedince Pencereyi Otomatik Gizle</sys:String>
    <sys:String x:Key="General_WindowPosition">Ana Pencere Konumu</sys:String>
    <sys:String x:Key="General_WindowAlign">Ana Pencere Ekran Konumu</sys:String>
    <sys:String x:Key="General_MainWindowMaxHeightRatio">Ana Pencere Maksimum Yüksekliği (Ekran Oranı)</sys:String>
    <sys:String x:Key="General_MainWindowMaxHeightRatioDescription">Maksimum ana pencere yüksekliğini mevcut monitör çalışma alanının oranı olarak kontrol eder (%60-100).</sys:String>
    <sys:String x:Key="General_DisableGlobalHotkeys">Genel Kısayolları Devre Dışı Bırak</sys:String>
    <sys:String x:Key="General_IgnoreHotkeysOnFullscreen">Tam Ekran Modunda Kısayolları Yoksay</sys:String>
    <sys:String x:Key="General_IgnoreHotkeysOnFullscreenDescription">"Genel Kısayolları Devre Dışı Bırak"tan daha düşük önceliğe sahiptir, genellikle oyun senaryolarında kullanılır.</sys:String>
    <sys:String x:Key="General_LanguageDetector">Dil Algılayıcı</sys:String>
    <sys:String x:Key="General_LocalDetector">Yerel Algılama Çince-İngilizce Karakter Oranı</sys:String>
    <sys:String x:Key="General_LocalDetectorDescription">Yalnızca Çince-İngilizce metindeki İngilizce karakterlerin toplam karakterlere oranı için "Yerel Algılama" seçeneğine uygulanır.</sys:String>
    <sys:String x:Key="General_DefaultSourceLanguage">Varsayılan Kaynak Dil</sys:String>
    <sys:String x:Key="General_DefaultSourceLanguageDescription">Otomatik algılama başarısız olduğunda bu dili kullanın.</sys:String>
    <sys:String x:Key="General_FirstLanguage">İlk Dil</sys:String>
    <sys:String x:Key="General_FirstLanguageDescription">Herhangi bir çeviri senaryosunda hedef dil Otomatik olarak ayarlandığında ve kaynak dil başka bir dil olduğunda (ikinci dil dahil), hedef dil ilk dili kullanır.</sys:String>
    <sys:String x:Key="General_SecondLanguage">İkinci Dil</sys:String>
    <sys:String x:Key="General_SecondLanguageDescription">Herhangi bir çeviri senaryosunda hedef dil Otomatik olarak ayarlandığında ve kaynak dil ilk dil olduğunda, hedef dil ikinci dili kullanır.</sys:String>
    <sys:String x:Key="General_HttpTimeout">Zaman Aşımı</sys:String>
    <sys:String x:Key="General_HttpTimeoutDescription">Ağ isteği zaman aşımı süresi (saniye).</sys:String>
    <sys:String x:Key="General_UseClipboardOutput">Metin Çıktısı için Pano Kullan</sys:String>
    <sys:String x:Key="General_UseClipboardOutputDescription">Etkinleştirildiğinde, metin çıktısı için pano Ctrl+V kullanılır; devre dışı bırakıldığında simüle edilmiş klavye girişi kullanılır (varsayılan).</sys:String>
    <sys:String x:Key="General_TranslateOnPaste">Yapıştırınca Çevir</sys:String>
    <sys:String x:Key="General_TranslateOnPasteDescription">Metin giriş kutusuna yapıştırıldığında çeviriyi hemen yürütün.</sys:String>
    <sys:String x:Key="General_AutoTranslate">Otomatik Çeviri</sys:String>
    <sys:String x:Key="General_AutoTranslateDescription">İçerik girilirken belirli bir bekleme süresinden sonra çeviriyi otomatik olarak yürütür.</sys:String>
    <sys:String x:Key="General_InstantTranslate">Anında Çeviri</sys:String>
    <sys:String x:Key="General_InstantTranslateDescription">Aşağıdaki eylemler gerçekleştiğinde çeviriyi hemen çalıştırın.</sys:String>
    <sys:String x:Key="General_AutoTranslateButtonVisible">Ana arayüzde otomatik çeviri düğmesini göster</sys:String>
    <sys:String x:Key="General_AutoTranslateOnPromptChanged">İstem Değiştirince Otomatik Çevir</sys:String>
    <sys:String x:Key="General_AutoTranslateOnPromptChangedDescription">AI çeviri hizmetleri için istem değiştirildikten sonra çeviriyi hemen yeniden çalıştırın.</sys:String>
    <sys:String x:Key="General_IncrementalClearInput">Kademeli Çeviride Girişi Temizle</sys:String>
    <sys:String x:Key="General_IncrementalClearInputDescription">Etkinleştirildiğinde (varsayılan), kademeli çeviri tetiklendiğinde giriş kutusu temizlenir; oturum sırasındaki seçimler yine de eklenir. Devre dışı bırakıldığında, önceki içerik korunur ve yeni seçimler buna eklenir.</sys:String>
    <sys:String x:Key="General_AutoTranslateDelay">Otomatik Çeviri Gecikmesi</sys:String>
    <sys:String x:Key="General_AutoTranslateDelayDescription">İçerik girdikten sonra bekleme süresi, birim: milisaniye.</sys:String>
    <sys:String x:Key="General_LineBreakHandleType">Satır Sonu İşleme</sys:String>
    <sys:String x:Key="General_LineBreakHandleTypeDescription" xml:space="preserve">Kelime seçimi, ekran görüntüsü çevirisi, pano ve sessiz OCR senaryoları için satır sonu işlemeyi içerir.&#10;"Fazladan satır sonlarını kaldır" özellikle PDF metin çıkarma içindir, gereksiz satır sonlarını ve cümle sonlarını kaldırır, ancak PDF dışı çıkarmayı etkileyebilir.</sys:String>
    <sys:String x:Key="General_TextSeparatorHandleType">Metin Ayırıcı İşleme</sys:String>
    <sys:String x:Key="General_TextSeparatorHandleTypeDescription">İngilizce/sayısal tanımlayıcıların içindeki alt çizgi veya kısa çizgileri boşluklara dönüştürür. Varsayılan olarak devre dışıdır.</sys:String>
    <sys:String x:Key="General_TextSeparatorHandleScopes">Ayırıcı İşleme Kapsamı</sys:String>
    <sys:String x:Key="General_TextSeparatorHandleScopesDescription">Metin yakalama giriş noktalarından hangilerine ayırıcı işleminin uygulanacağını seçin. Hiçbiri seçilmezse orijinal metin korunur.</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeout">Metin Yakalama Zaman Aşımı</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeoutDescription">Simüle edilmiş kopyalamadan sonra yeni pano metnini yoklama zaman aşımı, milisaniye cinsinden. Metin güncellenir güncellenmez geri döner; yavaş güncellenen PDF uygulamaları için bu değeri artırın.</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeoutPlaceholder">500</sys:String>
    <sys:String x:Key="General_CrosswordFetchFailedFallbackTarget">Kelime Seçimi Başarısızlık Yedeklemesi</sys:String>
    <sys:String x:Key="General_CrosswordFetchFailedFallbackTargetDescription">Seçili metin yakalama başarısız olduğunda, giriş çevirisine geçmeyi veya yalnızca ana pencereyi göstermeyi seçin.</sys:String>
    <sys:String x:Key="General_ImageQuality">Görüntü Kalitesi</sys:String>
    <sys:String x:Key="General_ImageQualityDescription">Görüntüleri işlerken kaliteyi ayarlayın. Çevrimiçi OCR hizmetleri görüntü boyutunu sınırlayabilir.</sys:String>
    <sys:String x:Key="General_DoubleClickTrayFunction">Tepsi Çift Tıklama İşlevi</sys:String>
    <sys:String x:Key="General_DoubleClickTrayFunctionDescription">"Yok" dışında herhangi bir eylem seçmek, tepsi tek tıklama ile ana pencereyi göster/gizle işlevini devre dışı bırakır.</sys:String>
    <sys:String x:Key="General_Language">Dil</sys:String>
    <sys:String x:Key="General_ScreenshotTranslate">Ekran Görüntüsü Çevirisi</sys:String>
    <sys:String x:Key="General_ImageTranslate">Görsel Çeviri</sys:String>
    <sys:String x:Key="General_ShowScreenshotTranslate">Ekran Görüntüsü Çevirisini Göster</sys:String>
    <sys:String x:Key="General_ShowScreenshotTranslateDescription">Ana arayüzde "Ekran Görüntüsü Çevirisi" düğmesini gösterin. Ekran görüntüsü alın, metni tanıyın, giriş kutusuna doldurun, ardından çeviriyi yapın.</sys:String>
    <sys:String x:Key="General_ShowImageTranslate">Görsel Çeviriyi Göster</sys:String>
    <sys:String x:Key="General_ShowImageTranslateDescription">Ana arayüzde "Görsel Çeviri" düğmesini gösterin. Ekran görüntüsü alın ve doğrudan görüntü üzerinde çevirin.</sys:String>
    <sys:String x:Key="General_ShowScreenshotAuxiliaryLines">Ekran Görüntüsü Yardımcı Çizgileri</sys:String>
    <sys:String x:Key="General_ShowScreenshotAuxiliaryLinesDescription">Ekran görüntüsü sırasında alan seçimine yardımcı olmak için yardımcı çizgiler gösterilip gösterilmeyeceği.</sys:String>
    <sys:String x:Key="General_HideNotifyIcon">Tepsi Simgesini Gizle</sys:String>
    <sys:String x:Key="General_ShowScreenshotItemInNotifyIconMenu">Tepsi Menüsünde Ekran Görüntüsü Çevirisini Göster</sys:String>
    <sys:String x:Key="General_ShowImageTranslateItemInNotifyIconMenu">Tepsi Menüsünde Görsel Çeviriyi Göster</sys:String>
    <sys:String x:Key="General_ShowOcrItemInNotifyIconMenu">Tepsi Menüsünde Metin Tanımayı Göster</sys:String>
    <sys:String x:Key="General_ShowQrCodeItemInNotifyIconMenu">Tepsi Menüsünde QR Kodu Göster</sys:String>
    <sys:String x:Key="General_ColorTheme">Renk Teması</sys:String>
    <sys:String x:Key="General_ColorThemeDescription">Görüntülenecek renk temasını seçin.</sys:String>
    <sys:String x:Key="General_ColorThemeButtonVisible">Ana arayüzde Renk Teması düğmesini göster</sys:String>
    <sys:String x:Key="General_HideInputBox">Giriş Kutusunu Gizle</sys:String>
    <sys:String x:Key="General_HideInputBoxDescription">Giriş kutusunun gizlenip gizlenmeyeceği.</sys:String>
    <sys:String x:Key="General_HideInputBoxButtonVisible">Ana arayüzde Giriş Kutusunu Gizle düğmesini göster</sys:String>
    <sys:String x:Key="General_HideLanguageControl">Dil Seçim Kontrolünü Gizle</sys:String>
    <sys:String x:Key="General_HideLanguageControlDescription">Giriş kutusu gizlendiğinde dil seçim kontrolünün gizlenip gizlenmeyeceği.</sys:String>
    <sys:String x:Key="General_ShowMouseHook">Fare Kancasını Göster</sys:String>
    <sys:String x:Key="General_ShowMouseHookDescription">Ana arayüzde fare ile kelime seçme özelliğini hızlıca etkinleştirme/devre dışı bırakma simgesinin gösterilip gösterilmeyeceği.</sys:String>
    <sys:String x:Key="General_ShowHistoryNavigation">Geçmiş Gezinmesini Göster</sys:String>
    <sys:String x:Key="General_ShowHistoryNavigationDescription">Ana arayüzde ileri/geri geçmiş çeviri gezinme simgelerinin gösterilip gösterilmeyeceği.</sys:String>
    <sys:String x:Key="General_ShowOcrButton">OCR Düğmesini Göster</sys:String>
    <sys:String x:Key="General_ShowOcrButtonDescription">Ana arayüzün başlık çubuğunda OCR düğmesini görüntüleyin.</sys:String>
    <sys:String x:Key="General_ShowClipboardMonitor">Pano İzleme Düğmesini Göster</sys:String>
    <sys:String x:Key="General_ShowClipboardMonitorDescription">Ana arayüzün başlık çubuğunda pano izleme açma/kapama düğmesini görüntüleyin.</sys:String>
    <sys:String x:Key="General_MainHeaderConfig">Ana Başlık Düğme Düzeni</sys:String>
    <sys:String x:Key="General_MainHeaderConfigDescription">Üst satır Önizleme, alt satır ise Eylem Havuzu'dur. Göstermek için havuzdan bir öğeyi Önizleme'ye sürükleyin, gizlemek için geri sürükleyin ve yeniden sıralamak için Önizleme içinde sürükleyin.</sys:String>
    <sys:String x:Key="General_MainHeaderPreview">Önizleme (Ana Başlık)</sys:String>
    <sys:String x:Key="General_MainHeaderPool">Eylem Havuzu (Gizli)</sys:String>
    <sys:String x:Key="General_MainHeaderShowAll">Tümünü Göster</sys:String>
    <sys:String x:Key="General_MainHeaderHideAll">Tümünü Gizle</sys:String>
    <sys:String x:Key="General_ShowCloseButton">Kapatma Düğmesini Göster</sys:String>
    <sys:String x:Key="General_ShowCloseButtonDescription">Ayarlar düğmesinin sağında kapatma düğmesini görüntüleyin. Esc tuşu ile aynı davranışı gösterir.</sys:String>
    <sys:String x:Key="General_FontSize">Yazı Tipi Boyutu</sys:String>
    <sys:String x:Key="General_FontSizeDescription">Sağ tıklama bağlam menüsü hariç tüm öğelerin yazı tipi boyutunu ayarlayın.</sys:String>
    <sys:String x:Key="General_OutputShowingControl">Çıktı Görüntüleme Kontrolü</sys:String>
    <sys:String x:Key="General_ShowPascalCase">PascalCase kopyalama düğmesini göster</sys:String>
    <sys:String x:Key="General_ShowCamelCase">camelCase kopyalama düğmesini göster</sys:String>
    <sys:String x:Key="General_ShowSnakeCase">snake_case kopyalama düğmesini göster</sys:String>
    <sys:String x:Key="General_ShowInsert">Metin ekleme düğmesini göster</sys:String>
    <sys:String x:Key="General_ShowBackTranslation">Geri çeviri düğmesini göster</sys:String>
    <sys:String x:Key="General_ShowPrompt">İstemi Göster</sys:String>
    <sys:String x:Key="General_ShowPromptDescription">AI çeviri hizmetleri için istem değiştirme düğmesinin ana arayüzde gösterilip gösterilmeyeceği.</sys:String>
    <sys:String x:Key="General_FontFamily">Yazı Tipi Ailesi</sys:String>
    <sys:String x:Key="General_HistoryCount">Geçmiş Sayısı</sys:String>
    <sys:String x:Key="General_CopyAfterTranslation">Çeviriden Sonra Kopyala</sys:String>
    <sys:String x:Key="General_CopyAfterTranslationDescription">Yalnızca "Otomatik" özelliğine sahip hizmetler için geçerlidir.</sys:String>
    <sys:String x:Key="General_CopyAfterTranslationNotAutomatic">"Otomatik" olmayan hizmetler için çeviriden sonra kopyala</sys:String>
    <sys:String x:Key="General_CopyAfterOcr">OCR'den Sonra Kopyala</sys:String>
    <sys:String x:Key="General_CopyAfterOcrDescription">Tüm metin tanıma senaryoları için, OCR'den sonra tanıma sonucunu otomatik olarak panoya kopyalayın.</sys:String>
    <sys:String x:Key="General_FocusInputAfterScreenshotTranslate">Ekran görüntüsü çevirisinden sonra girişi etkinleştir</sys:String>
    <sys:String x:Key="General_FocusInputAfterScreenshotTranslateDescription">Açık: Ekran görüntüsü çevirisinden sonra ana pencereyi gösterin ve giriş kutusuna odaklanın. Kapalı: ana pencere en üstteyse, odak çalmadan sonuçları güncelleyin; en üstte olmayan pencereler yine de yeniden açılır.</sys:String>
    <sys:String x:Key="General_PluginMarketCdnSource">Eklenti Pazarı CDN Kaynağı</sys:String>
    <sys:String x:Key="General_PluginMarketCdnSourceDescription">Eklenti pazarı verileri için CDN hızlandırma hizmetini seçin (GitHub doğrudan önbellek gecikmesi yoktur).</sys:String>
    <sys:String x:Key="General_CustomCdnUrl">Özel CDN URL'si</sys:String>
    <sys:String x:Key="General_CustomCdnUrlDescription">Özel CDN URL şablonunu girin, {author}, {repo}, {branch}, {path} yer tutucularını kullanın.</sys:String>

    <!--  // PluginMarketCdnSourceType //  -->
    <sys:String x:Key="PluginMarketCdnSourceTypeJsDelivr">jsDelivr CDN (Önerilir)</sys:String>
    <sys:String x:Key="PluginMarketCdnSourceTypeGitHubRaw">GitHub Doğrudan</sys:String>
    <sys:String x:Key="PluginMarketCdnSourceTypeCustom">Özel</sys:String>

    <!--  // PluginDownloadProxyType //  -->
