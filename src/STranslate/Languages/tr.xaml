    <!--  // Kısayol Sayfası //  -->
    <sys:String x:Key="GlobalHotkeys">Genel Kısayollar</sys:String>
    <sys:String x:Key="SoftwareHotkeys">Yazılım Kısayolları</sys:String>
    <sys:String x:Key="Hotkey_OpenSTranslate">STranslate'i Aç</sys:String>
    <sys:String x:Key="Hotkey_OpenSTranslateDescription">STranslate ana arayüzünü göster/gizle kısayolu.</sys:String>
    <sys:String x:Key="Hotkey_InputTranslate">Giriş Çevirisi</sys:String>
    <sys:String x:Key="Hotkey_InputTranslateDescription">STranslate'i açmak ve giriş çevirisi için içeriği temizlemek üzere kısayol tuşu.</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslate">Kelime Seçimi Çevirisi</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateDescription">Fare ile seçilen metnin çevirisini tetiklemek için kısayol tuşu.</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateIsUseCtrlSameC">Metin seçimi çevirisi için Ctrl+C+C kullanılsın mı?</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateTraditional">Geleneksel Kısayol</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateByCtrlSameCDescription">Metin çevirisi için fare ile metin seçtikten sonra hızlıca Ctrl+C+C tuşlarına basın.</sys:String>
    <sys:String x:Key="CrosswordTranslateFetchFailed">Seçili metin yakalanamadı, giriş çevirisine geçildi.</sys:String>
    <sys:String x:Key="CrosswordTranslateFetchFailedShowWindow">Seçili metin yakalanamadı, ana pencere görünümüne geçildi.</sys:String>
    <sys:String x:Key="Hotkey_MouseHookTranslate">Fare Kancası Çevirisi</sys:String>
    <sys:String x:Key="Hotkey_MouseHookTranslateDescription">Fare ile metin seçimini dinlemeyi etkinleştirmek/devre dışı bırakmak için kısayol tuşu.</sys:String>
    <sys:String x:Key="Hotkey_ReplaceTranslate">Değiştirerek Çeviri</sys:String>
    <sys:String x:Key="Hotkey_ReplaceTranslateDescription">Seçili metni çevirip orijinal metinle değiştirmek için kısayol tuşu.</sys:String>
    <sys:String x:Key="Hotkey_ScreenshotTranslate">Ekran Görüntüsü Çevirisi</sys:String>
    <sys:String x:Key="Hotkey_ScreenshotTranslateDescription">Seçili ekran alanını yakalamak, metni tanımak ve çevirmek için kısayol.</sys:String>
    <sys:String x:Key="Hotkey_ImageTranslate">Görsel Çeviri</sys:String>
    <sys:String x:Key="Hotkey_ImageTranslateDescription">Ekran görüntüsü almak, alan seçmek, metni tanımak ve doğrudan görüntü üzerinde çevirmek için kısayol.</sys:String>
    <sys:String x:Key="Hotkey_SilentOcr">Sessiz OCR</sys:String>
    <sys:String x:Key="Hotkey_SilentOcrDescription">Seçili ekran alanını yakalamak, metni tanımak ve panoya kopyalamak için kısayol.</sys:String>
    <sys:String x:Key="Hotkey_SilentTts">Sessiz TTS</sys:String>
    <sys:String x:Key="Hotkey_SilentTtsDescription">Fare ile seçilen Çince metnin konuşma sentezi için kısayol tuşu.</sys:String>
    <sys:String x:Key="Hotkey_Ocr">OCR (Metin Tanıma)</sys:String>
    <sys:String x:Key="Hotkey_OcrDescription">OCR penceresini açmak için kısayol.</sys:String>
    <sys:String x:Key="Hotkey_ClipboardMonitor">Pano İzleme Çevirisi</sys:String>
    <sys:String x:Key="Hotkey_ClipboardMonitorDescription">Pano izlemeyi aç/kapat. Etkinleştirildiğinde, pano değişiklikleri otomatik çeviriyi tetikler.</sys:String>
    <sys:String x:Key="ClipboardMonitorStarted">Pano izleme başlatıldı</sys:String>
    <sys:String x:Key="ClipboardMonitorStopped">Pano izleme durduruldu</sys:String>
    <sys:String x:Key="ClipboardMonitorButtonTooltip">Pano İzleme Çevirisi</sys:String>
